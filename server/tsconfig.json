{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "config/**/*.ts", "controllers/**/*.ts", "middleware/**/*.ts", "models/**/*.ts", "routes/**/*.ts", "services/**/*.ts", "repositories/**/*.ts", "utils/**/*.ts", "types/**/*.ts", "app.ts", "server.ts"]
}
